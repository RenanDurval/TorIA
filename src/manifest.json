{
  "manifest_version": 2,
  "name": "TorAI — IA Local Privada",
  "version": "1.0.0",
  "description": "Conecte modelos de IA locais (Ollama/LMStudio) ao Tor Browser com privacidade total. Nenhum dado sai do seu computador.",
  "author": "TorAI Project",
  "homepage_url": "https://github.com/torai-extension",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "TorAI — IA Local Privada"
  },

  "sidebar_action": {
    "default_title": "TorAI — Painel IA",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "commands": {
    "generate-summary": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Gerar resumo da página atual"
    },
    "translate-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+T"
      },
      "description": "Traduzir página para idioma selecionado"
    },
    "open-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+A"
      },
      "description": "Abrir/fechar painel TorAI"
    }
  },

  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src http://127.0.0.1:* http://localhost:*;",

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "torai@local.extension",
      "strict_min_version": "102.0"
    }
  }
}
